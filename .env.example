# Copy this file to .env and fill in your values
# .env is git-ignored — never commit secrets

# LLM
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434   # use 'http://ollama:11434' when running inside Docker
# UNIVERSITY_API_URL=https://...   # uncomment if using university API
# UNIVERSITY_API_KEY=your_key_here

# Embedding model (HuggingFace model name)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Retrieval
TOP_K=5
MIN_SCORE=0.35

# ChromaDB
CHROMA_HOST=localhost   # use 'chromadb' when running inside Docker
CHROMA_PORT=8000
COLLECTION_NAME=switzerland_geo

# Paths
GEONAMES_PATH=data/raw/CH.txt
CORPUS_PATH=data/processed/corpus.jsonl
